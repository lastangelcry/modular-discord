{
  "name": "modular-discord",
  "version": "1.1.0",
  "description": "Ядро модульного Discord-бота: загрузчик модулей, мульти-БД (SQLite, PostgreSQL, MySQL, MongoDB), формат .pak",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "modular-discord-pack": "dist/pack-module.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && node scripts/build-pack.mjs",
    "pack:module": "tsx scripts/pack-module.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "discord.js",
    "modular",
    "sqlite",
    "postgres",
    "mysql",
    "mongodb",
    "bot-framework"
  ],
  "author": "lastangelcry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lastangelcry/modular-discord.git"
  },
  "bugs": {
    "url": "https://github.com/lastangelcry/modular-discord/issues"
  },
  "homepage": "https://github.com/lastangelcry/modular-discord#readme",
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "discord.js": "^14.19.3",
    "esbuild": "^0.25.5",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.14",
    "mongodb": "^6.16.0",
    "mysql2": "^3.14.1",
    "pg": "^8.16.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "pg": ">=8.0.0",
    "mysql2": ">=3.0.0",
    "mongodb": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": true },
    "mysql2": { "optional": true },
    "mongodb": { "optional": true }
  }
}
